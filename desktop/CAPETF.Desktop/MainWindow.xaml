<Window x:Class="CAPETF.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CAPETF Realtime" Height="900" Width="1480" MinHeight="760" MinWidth="1180"
        Background="#0B1220" FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#111827"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#162033"/>
        <SolidColorBrush x:Key="LineBrush" Color="#263246"/>
        <SolidColorBrush x:Key="InkBrush" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#94A3B8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#22C55E"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="Margin" Value="0,4,0,9"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="Margin" Value="0,4,0,9"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="Margin" Value="0,4,0,9"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,4,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
        </Style>
        <Style TargetType="Expander">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="CAPETF" FontSize="25" FontWeight="SemiBold" Margin="0,0,18,0"/>
                    <TextBlock Text="Realtime workspace" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                    <Border Background="#0F172A" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="10,5" Margin="24,0,0,0">
                        <TextBlock x:Name="ResultText" Text="Connect and search to load instruments."/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="ConnectionText" Text="Disconnected" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <TextBlock x:Name="UpdatedText" Text="" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <Button Content="Disconnect" Click="Disconnect_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="292"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,10,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Account" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Each installed user keeps their own encrypted API keys." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,3,0,10"/>

                        <CheckBox x:Name="DemoCheck" Content="Use demo API" Foreground="{StaticResource InkBrush}" IsChecked="True" Margin="0,0,0,10"/>
                        <TextBlock Text="Identifier" Foreground="{StaticResource MutedBrush}"/>
                        <TextBox x:Name="IdentifierBox"/>
                        <TextBlock Text="API password" Foreground="{StaticResource MutedBrush}"/>
                        <PasswordBox x:Name="PasswordBox"/>
                        <TextBlock Text="API key" Foreground="{StaticResource MutedBrush}"/>
                        <PasswordBox x:Name="ApiKeyBox"/>

                        <Button Content="Connect" Click="Connect_Click" Background="#16A34A" BorderBrush="#16A34A"/>
                        <Button Content="Save keys locally" Click="SaveCredentials_Click"/>
                        <Button Content="Forget saved keys" Click="ForgetCredentials_Click" Foreground="#FCA5A5"/>

                        <Separator Margin="0,12" Background="{StaticResource LineBrush}"/>

                        <TextBlock Text="Markets" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Search" Foreground="{StaticResource MutedBrush}"/>
                        <TextBox x:Name="SearchBox" Text="ETF" KeyDown="SearchBox_KeyDown"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Dataset" Foreground="{StaticResource MutedBrush}"/>
                                <ComboBox x:Name="DatasetBox" SelectionChanged="DatasetBox_SelectionChanged">
                                    <ComboBoxItem Content="Stocks" IsSelected="True"/>
                                    <ComboBoxItem Content="ETFs"/>
                                    <ComboBoxItem Content="Watchlist"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Chart" Foreground="{StaticResource MutedBrush}"/>
                                <ComboBox x:Name="ChartModeBox" SelectionChanged="ChartModeBox_SelectionChanged">
                                    <ComboBoxItem Content="2H"/>
                                    <ComboBoxItem Content="4H"/>
                                    <ComboBoxItem Content="6H"/>
                                    <ComboBoxItem Content="Daily" IsSelected="True"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <Button Content="Search" Click="Search_Click"/>
                        <Button Content="Stream visible" Click="StreamVisible_Click" Background="#216E8A" BorderBrush="#216E8A"/>

                        <Separator Margin="0,12" Background="{StaticResource LineBrush}"/>

                        <TextBlock Text="Workspace Stats" FontSize="16" FontWeight="SemiBold"/>
                        <UniformGrid Columns="2" Margin="0,8,0,0">
                            <Border Background="#0F172A" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,6,6">
                                <StackPanel><TextBlock Text="Markets" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="MarketCountText" Text="0" FontSize="18" FontWeight="SemiBold"/></StackPanel>
                            </Border>
                            <Border Background="#0F172A" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                                <StackPanel><TextBlock Text="Watchlist" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="WatchCountText" Text="0" FontSize="18" FontWeight="SemiBold"/></StackPanel>
                            </Border>
                            <Border Background="#0F172A" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,6,0">
                                <StackPanel><TextBlock Text="Live" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="LiveCountText" Text="0" FontSize="18" FontWeight="SemiBold"/></StackPanel>
                            </Border>
                            <Border Background="#0F172A" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="8">
                                <StackPanel><TextBlock Text="Limit" Foreground="{StaticResource MutedBrush}"/><TextBlock Text="40" FontSize="18" FontWeight="SemiBold"/></StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,10,0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Market Groups" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Groups open on demand; streaming follows visible groups." Foreground="{StaticResource MutedBrush}"/>
                    </Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="GroupList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander Header="{Binding Header}" IsExpanded="{Binding IsExpanded}" Margin="0,0,0,8">
                                        <ItemsControl ItemsSource="{Binding Instruments}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="250" MinHeight="198" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,10,10" MouseLeftButtonUp="InstrumentCard_Click">
                                                        <StackPanel>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding Epic}" Foreground="{StaticResource MutedBrush}"/>
                                                                </StackPanel>
                                                                <Button Grid.Column="1" Content="{Binding WatchlistMarker}" Click="ToggleWatchlist_Click" Padding="7,3" Margin="8,0,0,0"/>
                                                            </Grid>
                                                            <Grid Margin="0,9,0,0">
                                                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                                                <StackPanel><TextBlock Text="Price" Foreground="{StaticResource MutedBrush}"/><TextBlock Text="{Binding Price, TargetNullValue=n/a}" FontWeight="SemiBold"/></StackPanel>
                                                                <StackPanel Grid.Column="1"><TextBlock Text="Move" Foreground="{StaticResource MutedBrush}"/><TextBlock Text="{Binding IntradayReturn, StringFormat={}{0:+0.00;-0.00;0.00}%}" FontWeight="SemiBold"/></StackPanel>
                                                                <StackPanel Grid.Column="2"><TextBlock Text="Spread" Foreground="{StaticResource MutedBrush}"/><TextBlock Text="{Binding Spread, TargetNullValue=n/a}" FontWeight="SemiBold"/></StackPanel>
                                                            </Grid>
                                                            <Canvas Height="58" Margin="0,10,0,0" Loaded="MiniChart_Loaded" SizeChanged="MiniChart_SizeChanged"/>
                                                            <Grid Margin="0,9,0,0">
                                                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding TrendLabel}" Foreground="#86EFAC"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding AlertText}" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right"/>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                <TabControl Background="{StaticResource PanelBrush}" Foreground="{StaticResource InkBrush}">
                    <TabItem Header="Chart">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock x:Name="SelectedNameText" Text="No selection" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock x:Name="SelectedEpicText" Text="" Foreground="{StaticResource MutedBrush}"/>
                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="Bid" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="BidText" Text="n/a" FontWeight="SemiBold"/></StackPanel>
                                    <StackPanel Grid.Column="1"><TextBlock Text="Offer" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="OfferText" Text="n/a" FontWeight="SemiBold"/></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Text="Last" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="PriceText" Text="n/a" FontWeight="SemiBold"/></StackPanel>
                                </Grid>
                                <Canvas x:Name="DetailChart" Height="260" Background="#0F172A" Margin="0,18,0,0" SizeChanged="DetailChart_SizeChanged"/>
                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="SMA 20" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="Sma20Text" Text="n/a" FontWeight="SemiBold"/></StackPanel>
                                    <StackPanel Grid.Column="1"><TextBlock Text="SMA 50" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="Sma50Text" Text="n/a" FontWeight="SemiBold"/></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Text="Signal" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="TrendText" Text="n/a" FontWeight="SemiBold"/></StackPanel>
                                </Grid>
                                <TextBlock x:Name="DetailStatusText" Text="" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,12,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Alert">
                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="Price Alert" FontSize="17" FontWeight="SemiBold"/>
                            <TextBlock Text="Local alert checks against the latest streamed or refreshed price." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,12"/>
                            <TextBlock Text="Trigger price" Foreground="{StaticResource MutedBrush}"/>
                            <TextBox x:Name="AlertPriceBox"/>
                            <Button Content="Save alert" Click="SaveAlert_Click" Background="#216E8A" BorderBrush="#216E8A"/>
                            <Button Content="Clear alert" Click="ClearAlert_Click"/>
                            <TextBlock x:Name="AlertStatusText" Text="Select an instrument to manage alerts." TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,0"/>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Ticket">
                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="Order Ticket Preview" FontSize="17" FontWeight="SemiBold"/>
                            <TextBlock Text="Analysis only. No live orders are submitted from this build." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Button Content="Buy" Background="#16A34A" BorderBrush="#16A34A"/>
                                <Button Grid.Column="2" Content="Sell" Background="#B14242" BorderBrush="#B14242"/>
                            </Grid>
                            <TextBlock Text="Quantity" Foreground="{StaticResource MutedBrush}"/>
                            <TextBox x:Name="QuantityBox" Text="1"/>
                            <TextBlock Text="Stop loss" Foreground="{StaticResource MutedBrush}"/>
                            <TextBox x:Name="StopLossBox"/>
                            <TextBlock Text="Take profit" Foreground="{StaticResource MutedBrush}"/>
                            <TextBox x:Name="TakeProfitBox"/>
                            <TextBlock x:Name="TicketSummaryText" Text="Select an instrument to prepare a ticket." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,12,0,0"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
