<Window x:Class="CAPETF.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CAPETF Realtime" Height="860" Width="1320" MinHeight="720" MinWidth="1120"
        Background="#F5F6F4" FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="Margin" Value="0,4,0,10"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="Margin" Value="0,4,0,10"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="Margin" Value="0,4,0,10"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,4,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="CAPETF Realtime" FontSize="25" FontWeight="SemiBold" Foreground="#1D2939"/>
                    <TextBlock Text="Capital.com local dashboard with user-owned API keys and live visible-watchlist streaming" Foreground="#667085" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="ConnectionText" Text="Disconnected" Foreground="#667085" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Content="Disconnect" Click="Disconnect_Click" Background="#FFFFFF" Foreground="#1D2939" BorderBrush="#D0D5DD"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,12,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="API Access" FontSize="17" FontWeight="SemiBold"/>
                        <TextBlock Text="Credentials are encrypted for this Windows user." Foreground="#667085" TextWrapping="Wrap" Margin="0,4,0,12"/>

                        <CheckBox x:Name="DemoCheck" Content="Use demo API" IsChecked="True" Margin="0,0,0,10"/>
                        <TextBlock Text="Identifier"/>
                        <TextBox x:Name="IdentifierBox" />
                        <TextBlock Text="API password"/>
                        <PasswordBox x:Name="PasswordBox" />
                        <TextBlock Text="API key"/>
                        <PasswordBox x:Name="ApiKeyBox" />

                        <Button Content="Connect" Click="Connect_Click" Background="#1D2939" Foreground="#FFFFFF" BorderBrush="#1D2939"/>
                        <Button Content="Save keys locally" Click="SaveCredentials_Click" Background="#FFFFFF" Foreground="#1D2939" BorderBrush="#D0D5DD"/>
                        <Button Content="Forget saved keys" Click="ForgetCredentials_Click" Background="#FFFFFF" Foreground="#B14242" BorderBrush="#E4E7EC"/>

                        <Separator Margin="0,12"/>

                        <TextBlock Text="Search Instruments" FontSize="17" FontWeight="SemiBold"/>
                        <TextBox x:Name="SearchBox" Text="ETF" KeyDown="SearchBox_KeyDown"/>
                        <Button Content="Search" Click="Search_Click" Background="#1D2939" Foreground="#FFFFFF" BorderBrush="#1D2939"/>

                        <TextBlock Text="Dataset"/>
                        <ComboBox x:Name="DatasetBox" SelectionChanged="DatasetBox_SelectionChanged">
                            <ComboBoxItem Content="Stocks" IsSelected="True"/>
                            <ComboBoxItem Content="ETFs"/>
                            <ComboBoxItem Content="Watchlist"/>
                        </ComboBox>

                        <TextBlock Text="Chart"/>
                        <ComboBox x:Name="ChartModeBox" SelectionChanged="ChartModeBox_SelectionChanged">
                            <ComboBoxItem Content="2H"/>
                            <ComboBoxItem Content="4H"/>
                            <ComboBoxItem Content="6H"/>
                            <ComboBoxItem Content="Daily" IsSelected="True"/>
                        </ComboBox>

                        <Button Content="Start realtime for visible" Click="StreamVisible_Click" Background="#167A5A" Foreground="#FFFFFF" BorderBrush="#167A5A"/>
                        <TextBlock Text="Realtime is capped at 40 visible instruments by Capital.com." Foreground="#667085" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,12,0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ResultText" Text="Connect and search to load instruments." FontWeight="SemiBold" FontSize="15"/>
                        <TextBlock x:Name="UpdatedText" Grid.Column="1" Text="" Foreground="#667085"/>
                    </Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="GroupList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander Header="{Binding Header}" IsExpanded="{Binding IsExpanded}" Margin="0,0,0,8">
                                        <ItemsControl ItemsSource="{Binding Instruments}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="260" MinHeight="178" Background="#FFFFFF" BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,10,10" MouseLeftButtonUp="InstrumentCard_Click">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding Epic}" Foreground="#667085"/>
                                                            <Grid Margin="0,8,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition/>
                                                                    <ColumnDefinition/>
                                                                    <ColumnDefinition/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel><TextBlock Text="Price" Foreground="#667085"/><TextBlock Text="{Binding Price, TargetNullValue=n/a}" FontWeight="SemiBold"/></StackPanel>
                                                                <StackPanel Grid.Column="1"><TextBlock Text="Intraday" Foreground="#667085"/><TextBlock Text="{Binding IntradayReturn, StringFormat={}{0:+0.00;-0.00;0.00}%}" FontWeight="SemiBold"/></StackPanel>
                                                                <StackPanel Grid.Column="2"><TextBlock Text="Status" Foreground="#667085"/><TextBlock Text="{Binding Status}" FontWeight="SemiBold"/></StackPanel>
                                                            </Grid>
                                                            <Canvas Height="58" Margin="0,10,0,0" Loaded="MiniChart_Loaded" SizeChanged="MiniChart_SizeChanged"/>
                                                            <TextBlock Text="{Binding LastTickAt, StringFormat=Last tick {0:HH:mm:ss}}" Foreground="#667085" Margin="0,8,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="8" Padding="14">
                <StackPanel>
                    <TextBlock Text="Selected Instrument" FontSize="17" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SelectedNameText" Text="No selection" FontSize="20" FontWeight="SemiBold" Margin="0,14,0,0" TextWrapping="Wrap"/>
                    <TextBlock x:Name="SelectedEpicText" Text="" Foreground="#667085"/>
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="Bid" Foreground="#667085"/><TextBlock x:Name="BidText" Text="n/a" FontWeight="SemiBold"/></StackPanel>
                        <StackPanel Grid.Column="1"><TextBlock Text="Offer" Foreground="#667085"/><TextBlock x:Name="OfferText" Text="n/a" FontWeight="SemiBold"/></StackPanel>
                        <StackPanel Grid.Column="2"><TextBlock Text="Last" Foreground="#667085"/><TextBlock x:Name="PriceText" Text="n/a" FontWeight="SemiBold"/></StackPanel>
                    </Grid>
                    <Canvas x:Name="DetailChart" Height="260" Background="#FAFAFA" Margin="0,18,0,0" SizeChanged="DetailChart_SizeChanged"/>
                    <TextBlock x:Name="DetailStatusText" Text="" Foreground="#667085" TextWrapping="Wrap" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
